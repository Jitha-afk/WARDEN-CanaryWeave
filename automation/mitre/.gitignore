# Local virtualenv for this automation (Python 3.12; mitreattack-python needs 3.11-3.13).
.venv/

# All generated data is regenerable by running the pipeline: raw upstream bundles
# (data/raw/), normalized per-framework dumps (data/normalized/), and the
# WARDEN/MCP transform outputs (data/warden/). Only code and docs are tracked;
# run `python run_all.py` to (re)build everything under data/.
data/

__pycache__/
*.pyc
