id: cwfr-demo-0002
name: MCPToolPathBoundaryRule
version: 0.1.0
category: demo/mcp_tool_path_boundary
severity: high
scope: prompt
description: Detects an MCP tool call shape that requests file access outside an allowed workspace boundary.
meta:
  author: Project Open Hand Monk
  status: demo
keywords:
  - name: mcp_tool_call
    type: exact
    value: tool_call
  - name: read_file
    type: exact
    value: read_file
  - name: relative_parent_path
    type: exact
    value: ".."
semantics:
  - name: path_boundary_escape
    description: Prompt requests file or resource access outside the authorized workspace boundary.
    threshold: 0.70
  - name: mcp_tool_path_access
    description: Prompt is shaped like an MCP tool call requesting path-based resource access.
    threshold: 0.70
fides:
  - name: path_boundary_judge
    prompt: Assess whether public-safe normalized facts indicate an MCP tool path-boundary violation.
    threshold: 0.65
signals:
  - name: path_boundary_shape
    type: feature_flag
    feature: path_boundary_shape
  - name: capability_not_granted
    type: capability_policy
    relation: not_in_allowed_capabilities
condition: signals.path_boundary_shape and signals.capability_not_granted
recommended_action: block_and_audit
fixtures:
  positive:
    - demo_mcp_tool_path_boundary_request
  negative:
    - demo_allowed_workspace_read
safety_notes: Demo rule uses a synthetic relative-path shape only; no sensitive filesystem path or real private file is included.
