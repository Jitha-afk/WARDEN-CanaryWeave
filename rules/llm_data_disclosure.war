// CanaryWeave WARDEN policy ruleset: LLM data disclosure & unsafe output
// (ATLAS AML.T0056 / AML.T0057).
//
// Structured 4-evidence rules for system-prompt extraction, sensitive-data
// disclosure, and downstream-executable output. Patterns + a built-in MCP fact +
// an engine semantic + a FIDES judge question. Public-safe indicators only.

rule SystemPromptExtraction {
    meta:
        id          = cwfr-llm-0011
        version     = 0.1.0
        severity    = high
        scope          = event_window
        action      = block_and_audit
        technique   = AML.T0056 (Exfiltration, direct)
        defense     = D3-OTF (Outbound Traffic Filtering)
        author      = "Project Open Hand Monk"
        status      = experimental
        description = "Detects requests to disclose the assistant's hidden system prompt, developer instructions, or internal configuration."
        safety      = "Structural extraction indicators only; no protected prompt text."
    patterns:
        $reveal_prompt   = /\b(?:show|reveal|display|print|repeat|reproduce|output|leak|tell\s+me)\b[^.\n]{0,30}\b(?:your\s+)?(?:system\s+prompt|initial\s+(?:instructions?|prompt)|hidden\s+(?:instructions?|prompt)|developer\s+(?:instructions?|message)|configuration)\b/i
        $verbatim_request = /\b(?:verbatim|word\s+for\s+word|exactly\s+as\s+(?:written|given|provided)|everything\s+(?:above|before\s+this\s+(?:message|line)))\b/i
    semantics:
        $extraction_intent = "Content asks the assistant to disclose its hidden system prompt, developer instructions, or internal configuration." (0.70)
    judge:
        $extraction_judge = "Assess whether public-safe facts indicate a request to disclose protected system-prompt or instruction content." (0.65)
    condition:
        (($reveal_prompt or $verbatim_request) and $from_untrusted_origin) or $extraction_intent or $extraction_judge
}

rule SensitiveInformationDisclosure {
    meta:
        id          = cwfr-llm-0012
        version     = 0.1.0
        severity    = high
        scope       = event_window
        action      = block_and_audit
        technique   = AML.T0057 (Exfiltration, direct)
        defense     = D3-OTF (Outbound Traffic Filtering)
        author      = "Project Open Hand Monk"
        status      = experimental
        description = "Detects attempts to elicit sensitive personal, secret, or proprietary information the assistant should not reveal."
        safety      = "Structural sensitive-data indicators only; no real secrets or PII."
    patterns:
        $sensitive_request  = /\b(?:list|show|dump|reveal|provide|give\s+me|extract)\b[^.\n]{0,30}\b(?:all\s+)?(?:passwords?|api[\s_-]?keys?|secrets?|credentials?|tokens?|private\s+keys?|ssn|social\s+security|credit\s+card|personal\s+(?:data|information)|customer\s+(?:data|records?)|training\s+data)\b/i
        $confidential_target = /\b(?:confidential|proprietary|internal[\s-]?only|classified|non[\s-]?public)\b[^.\n]{0,30}\b(?:data|information|document|records?|details?)\b/i
    semantics:
        $disclosure_intent = "Content seeks disclosure of sensitive personal, secret, or proprietary information the assistant should not reveal." (0.70)
    judge:
        $disclosure_judge = "Assess whether public-safe facts indicate an attempt to elicit sensitive personal, secret, or proprietary data." (0.65)
    condition:
        (($sensitive_request or $confidential_target) and $capability_denied) or $disclosure_intent or $disclosure_judge
}

rule UnsafeOutputHandling {
    meta:
        id          = cwfr-llm-0013
        version     = 0.1.0
        severity    = high
        scope       = event_window
        action      = block_and_audit
        technique   = AML.T0057 (Exfiltration, analogical), T1059 (Execution, analogical)
        defense     = D3-EI (Execution Isolation)
        author      = "Project Open Hand Monk"
        status      = experimental
        description = "Detects content shaping assistant output into markup, SQL, or shell that a downstream system would execute without validation."
        safety      = "Structural injection indicators only; no working exploit payloads."
    patterns:
        $injected_markup = /<script\b|javascript:|onerror\s*=|onload\s*=|<iframe\b|<img\b[^>]*\bsrc\s*=/i
        $sqli_or_shell   = /\b(?:union\s+select|drop\s+table|insert\s+into|;\s*(?:rm|del|shutdown)\b)|\$\([^)]*\)|--\s*$|\bor\s+1\s*=\s*1\b/i
    semantics:
        $unsafe_output_intent = "Content steers the assistant to emit markup, SQL, or shell that a downstream system would execute without validation." (0.70)
    judge:
        $unsafe_output_judge = "Assess whether public-safe facts indicate output is being shaped to inject into or execute on a downstream system." (0.65)
    condition:
        (($injected_markup or $sqli_or_shell) and $tool_call_shape) or $unsafe_output_intent or $unsafe_output_judge
}
