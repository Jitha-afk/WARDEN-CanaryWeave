// CanaryWeave WARDEN policy ruleset: prompt & instruction boundary.
//
// These rules watch untrusted MCP-visible content for instruction-injection
// shape, invisible text structure, protected-context extraction, and deceptive
// tasking. Each carries a FIDES judge question for the IFC gate to adjudicate.

rule UntrustedInstructionShape {
    meta:
        id          = cwfr-0003
        version     = 0.1.0
        severity    = medium
        scope       = text_field
        action      = quarantine
        technique   = AML.T0051 (Initial Access, direct)
        author      = "Project Open Hand Monk"
        status      = experimental
        description = "Detects instruction-like structure in an untrusted MCP field using structural markers rather than copied payload strings."
        safety      = "Structural demonstration text only; excludes payload examples."
    patterns:
        $injected_directive = /\b(?:ignore|disregard|override|forget|bypass)\b[^.\n]{0,20}\b(?:previous|prior|above|earlier|all|the\s+system)\b[^.\n]{0,20}\b(?:instructions?|rules?|prompts?|directions?|guidelines?)\b|\b(?:new\s+(?:instructions?|task|directive)\s*[:=]?|system\s+(?:override|prompt)\s*[:=]?|you\s+must\s+now)\b/i
        $role_redirect      = /\[\s*(?:system|assistant|instruction|developer)\s*\]|<\s*(?:system|instruction|im_start|im_end)\s*>|<\|(?:system|im_start)\|>/i
    condition:
        (($injected_directive or $role_redirect) and $instruction_shape) or ($instruction_shape and $from_untrusted_origin)
}

rule HiddenUnicodeStructure {
    meta:
        id          = cwfr-0004
        version     = 0.1.0
        severity    = medium
        scope       = text_field
        action      = quarantine
        technique   = T1027 (Defense Evasion, analogical)
        author      = "Project Open Hand Monk"
        status      = experimental
        description = "Detects invisible or normalization-changing text structure in MCP-visible fields."
        safety      = "Synthetic text with a zero-width separator only."
    patterns:
        $unicode_tags = /[\U000E0000-\U000E007F]{2,}/
        $zero_width   = /[\u200B-\u200F\u2060\u2063\uFEFF\u00AD\u034F\u180E]/
    semantics:
        $hidden_structure_intent = "Text carries invisible, zero-width, or normalization-changing characters that conceal instructions from a human reader." (0.70)
    judge:
        $hidden_unicode_judge = "Assess whether public-safe facts indicate invisible or normalization-changing text structure." (0.65)
    condition:
        $unicode_tags or $zero_width or $hidden_unicode or $hidden_structure_intent or $hidden_unicode_judge
}

rule ProtectedContextExtraction {
    meta:
        id          = cwfr-0108
        version     = 0.1.0
        severity    = medium
        scope       = event_window
        action      = quarantine
        technique   = AML.T0056 (Exfiltration, analogical)
        defense     = D3-OTF (Outbound Traffic Filtering)
        author      = "Project Open Hand Monk"
        status      = experimental
        description = "Detects untrusted content requesting protected prompt, policy, schema, or hidden runtime context disclosure."
        safety      = "Structural protected-context indicators only; no protected prompt text or private schemas."
    patterns:
        $reveal_context = /\b(?:show|reveal|display|print|repeat|dump|output|leak|disclose|tell\s+me)\b[^.\n]{0,30}\b(?:your\s+)?(?:system\s+prompt|initial\s+(?:instructions?|prompt)|hidden\s+(?:instructions?|prompt|context)|developer\s+(?:message|instructions?)|(?:tool|function)\s+schema|configuration|guardrails?)\b/i
        $context_probe  = /\b(?:what\s+(?:are|were)\s+your\s+(?:exact\s+)?(?:instructions?|rules?|directives?)|everything\s+(?:above|before)\s+this\s+(?:message|line)|repeat\s+the\s+(?:text|words)\s+above|word\s+for\s+word)\b/i
        $target_context = /\b(?:target|extract|access|retrieve|obtain|get)\w*\b[^.\n]{0,30}\b(?:hidden|system|internal|protected|private)\s+(?:prompt|context|instructions?|policy|schema|configuration)\b/i
    semantics:
        $context_extraction_intent = "Content attempts to extract, reveal, or disclose protected system prompt, developer instructions, hidden context, tool schemas, or runtime configuration." (0.70)
    condition:
        ($reveal_context or $context_probe or $target_context or $context_extraction_intent) and $from_untrusted_origin
}

rule DeceptiveSocialEngineeringTasking {
    meta:
        id          = cwfr-0110
        version     = 0.1.0
        severity    = medium
        scope       = event_window
        action      = quarantine
        technique   = AML.T0052 (Initial Access, analogical)
        defense     = D3-UBA (User Behavior Analysis)
        author      = "Project Open Hand Monk"
        status      = experimental
        description = "Detects untrusted tasking that combines target-oriented social engineering with deceptive intent."
        safety      = "Structural social-engineering indicators only; no lure text, target details, or operational instructions."
    patterns:
        $social_lure    = /\b(?:phishing|spear[\s-]?phishing|impersonat\w*|pose\s+as|pretend\s+to\s+be|masquerad\w*\s+as|spoof\w*)\b|\b(?:urgent(?:ly)?\s+(?:verify|confirm|update)|click\s+(?:here|the\s+link)\s+to\s+(?:verify|confirm|reset)|enter\s+your\s+(?:password|credentials|login))\b/i
        $target_profile = /\b(?:build|compile|gather|collect|put\s+together)\b[^.\n]{0,30}\b(?:profile|dossier|background\s+(?:check|report)|personal\s+(?:information|details)|home\s+address|phone\s+number)\b/i
    condition:
        ($social_lure or $target_profile) and $from_untrusted_origin
}
