// CanaryWeave WARDEN policy ruleset: agentic trust boundaries.
//
// These rules guard the MCP origin-authority boundary and the canary data-flow
// boundary — the two places where untrusted server content tries to act with
// host authority or pull protected markers past an allowed sink.

rule ServerSamplingOriginBoundary {
    meta:
        id          = cwfr-0001
        version     = 0.2.0
        severity    = high
        scope       = event_window
        action      = block_and_audit
        technique   = T1059 (Execution, analogical)
        defense     = D3-AM (Access Mediation)
        author      = "Project Open Hand Monk"
        status      = experimental
        description = "Detects server-originated sampled content being treated as host-authoritative tool policy."
        safety      = "Synthetic structural facts only; no raw payload text or live sinks."
    patterns:
        $authority_directive = /\b(?:as\s+(?:the\s+)?(?:system|admin(?:istrator)?|host|operator|root)|on\s+behalf\s+of\s+the\s+(?:system|host|user)|you\s+are\s+(?:authori[sz]ed|approved|cleared|permitted)\s+to)\b[^.\n]{0,30}\b(?:run|execute|invoke|call|dispatch|approve|perform)\b/i
        $tool_dispatch_claim = /\b(?:the\s+(?:system|host|policy)\s+(?:says|requires|instructs|approves|authori[sz]es)|automatically\s+(?:approve|allow|run|execute)|no\s+(?:confirmation|approval|review)\s+(?:is\s+)?(?:needed|required))\b[^.\n]{0,30}\b(?:tool|command|action|function|call)\b/i
}

rule CanaryBoundaryCrossing {
    meta:
        id          = cwfr-0002
        version     = 0.1.0
        severity    = critical
        scope       = trace
        action      = block_and_audit
        technique   = AML.T0025 (Exfiltration, analogical)
        author      = "Project Open Hand Monk"
        status      = experimental
        description = "Detects a benign canary marker appearing outside an allowed event or sink boundary."
        safety      = "Uses benign synthetic marker labels only."
    patterns:
        $canary_marker = /\bcanary[\s_-]?(?:token|marker|tag|string|value|secret)\b|\bhoney[\s_-]?token\b/i
        $marker_egress = /\b(?:forward|send|exfiltrate|post|upload|leak|email|transmit|copy|relay)\b[^.\n]{0,40}\b(?:canary|honeytoken|marker|token|beacon)\b/i
    semantics:
        $canary_intent = "A protected canary or honeytoken marker is being moved toward an output, sink, or external destination outside its allowed boundary." (0.70)
    judge:
        $canary_judge = "Assess whether public-safe facts indicate a protected canary marker moved outside an allowed boundary." (0.65)
    condition:
        $canary_outside_sink or $canary_marker or $marker_egress or $canary_intent or $canary_judge
}
