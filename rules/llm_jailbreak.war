// CanaryWeave WARDEN policy ruleset: LLM jailbreak family (ATLAS AML.T0054).
//
// Structured 4-evidence rules: deterministic patterns, a built-in MCP fact in
// the condition, an engine semantic for intent, and a FIDES judge question.
// Public-safe generic indicators only; no dataset prompt strings.

rule RoleplayPersonaJailbreak {
    meta:
        id          = cwfr-llm-0004
        version     = 0.1.0
        severity    = high
        scope       = text_field
        action      = block_and_audit
        technique   = AML.T0054 (Privilege Escalation, direct)
        author      = "Project Open Hand Monk"
        status      = experimental
        description = "Detects requests to adopt a fictional persona or character whose purpose is to evade content or safety restrictions."
        safety      = "Generic persona-bypass phrasing only; no memorized benchmark prompts."
    patterns:
        $persona_adopt          = /\b(?:you\s+are\s+now|act\s+as|pretend\s+(?:to\s+be|you(?:'re|\s+are))|roleplay\s+(?:as|a)|imagine\s+you\s+are|stay\s+in\s+character\s+as)\b/i
        $unrestricted_character = /\b(?:no\s+(?:restrictions?|rules?|limits?|filters?|ethics?)|without\s+(?:restrictions?|limits?|filters?|censorship)|ignores?\s+(?:all\s+)?(?:guidelines?|policies|rules?)|can\s+(?:do|say)\s+anything)\b/i
    semantics:
        $roleplay_intent = "Content asks the assistant to adopt a fictional persona or character in order to evade content or safety restrictions." (0.70)
    judge:
        $roleplay_judge = "Assess whether public-safe facts indicate a roleplay or persona request intended to bypass safety guidelines." (0.65)
    condition:
        (($persona_adopt or $unrestricted_character) and $from_untrusted_origin) or $roleplay_intent or $roleplay_judge
}

rule KnownJailbreakTemplate {
    meta:
        id          = cwfr-llm-0005
        version     = 0.1.0
        severity    = high
        scope       = text_field
        action      = block_and_audit
        technique   = AML.T0054 (Privilege Escalation, direct)
        author      = "Project Open Hand Monk"
        status      = experimental
        description = "Detects well-known jailbreak personas and alternate unrestricted modes used to strip the assistant's safety constraints."
        safety      = "Structural template indicators only; no full jailbreak payloads."
    patterns:
        $named_jailbreak = /\b(?:DAN|STAN|DUDE|AIM|do\s+anything\s+now|developer\s+mode|jailbreak(?:en|ed)?|unlocked\s+mode|sudo\s+mode|god\s+mode)\b/i
        $mode_toggle     = /\b(?:enable|activate|turn\s+on|switch\s+to|enter)\b[^.\n]{0,20}\b(?:developer|debug|admin(?:istrator)?|unrestricted|unfiltered|uncensored)\s+mode\b/i
    semantics:
        $known_template_intent = "Content invokes a well-known jailbreak persona or alternate mode designed to remove the assistant's safety constraints." (0.70)
    judge:
        $known_template_judge = "Assess whether public-safe facts indicate use of a known jailbreak template or alternate unrestricted mode." (0.65)
    condition:
        (($named_jailbreak or $mode_toggle) and $from_untrusted_origin) or $known_template_intent or $known_template_judge
}

rule CognitiveHypotheticalJailbreak {
    meta:
        id          = cwfr-llm-0006
        version     = 0.1.0
        severity    = medium
        scope       = text_field
        action      = quarantine
        technique   = AML.T0054 (Privilege Escalation, direct)
        author      = "Project Open Hand Monk"
        status      = experimental
        description = "Detects hypothetical, fictional, or academic framings used as a pretext to elicit otherwise-restricted output."
        safety      = "Structural pretext indicators only; no harmful exemplar content."
    patterns:
        $hypothetical_frame = /\b(?:hypothetical(?:ly)?|imagine\s+(?:a\s+world|that)|in\s+a\s+fictional|thought\s+experiment|purely\s+(?:academic|theoretical)|for\s+(?:educational|research)\s+purposes\s+only|creative\s+writing\s+exercise)\b/i
        $safe_pretext       = /\b(?:this\s+is\s+(?:just\s+)?(?:a\s+)?(?:safe\s+space|fiction|story|game)|no\s+(?:real|actual)\s+harm|just\s+pretend|in\s+this\s+scenario\s+you)\b/i
    semantics:
        $cognitive_intent = "Content uses a hypothetical, fictional, or academic framing as a pretext to elicit otherwise-restricted output." (0.70)
    judge:
        $cognitive_judge = "Assess whether public-safe facts indicate a hypothetical or academic pretext is being used to bypass restrictions." (0.65)
    condition:
        (($hypothetical_frame and $safe_pretext) and $from_untrusted_origin) or $cognitive_intent or $cognitive_judge
}

rule PolicyPuppetryBypass {
    meta:
        id          = cwfr-llm-0007
        version     = 0.1.0
        severity    = high
        scope       = text_field
        action      = block_and_audit
        technique   = AML.T0054 (Privilege Escalation, direct)
        author      = "Project Open Hand Monk"
        status      = experimental
        description = "Detects content structured like a configuration or policy file that purports to authorize the assistant to ignore its safety rules."
        safety      = "Structural policy-markup indicators only; no operational bypass payloads."
    patterns:
        $policy_markup   = /<\s*(?:interaction[\s-]?config|policy|rule[\s-]?set|system[\s-]?config|allowed[\s-]?modes?)\s*>|"?(?:allowed_responses|blocked_modes|policy_override|safety_level)"?\s*[:=]\s*(?:\[|"|')/i
        $authority_claim = /\b(?:this\s+(?:policy|config(?:uration)?|rule\s*set)\s+(?:permits|allows|authorizes|overrides|disables)|as\s+(?:per|defined\s+in)\s+(?:the\s+)?(?:policy|config|ruleset))\b/i
    semantics:
        $puppetry_intent = "Content is structured like a configuration or policy file that purports to authorize the assistant to ignore its safety rules." (0.70)
    judge:
        $puppetry_judge = "Assess whether public-safe facts indicate a fabricated policy or config structure is being used to license disallowed behavior." (0.65)
    condition:
        (($policy_markup or $authority_claim) and $from_untrusted_origin) or $puppetry_intent or $puppetry_judge
}
