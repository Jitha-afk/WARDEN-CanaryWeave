// CanaryWeave WARDEN policy ruleset: LLM prompt-injection family (ATLAS AML.T0051).
//
// Structured 4-evidence rules: deterministic patterns over the raw text, a
// built-in MCP fact in the condition (origin / instruction shape / tool shape),
// an engine semantic for intent, and a FIDES judge question for the IFC gate.
// Public-safe generic indicators only; no dataset prompt strings.

rule DirectInstructionOverride {
    meta:
        id          = cwfr-llm-0001
        version     = 0.1.0
        severity    = high
        scope       = text_field
        action      = block_and_audit
        technique   = AML.T0051.000 (Initial Access, direct)
        author      = "Project Open Hand Monk"
        status      = experimental
        description = "Detects content that tries to override, cancel, or redefine the assistant's governing instructions or guardrails."
        safety      = "Generic instruction-override phrasing only; no memorized benchmark prompts."
    patterns:
        $override_phrase    = /(?:ignore|disregard|forget|override|bypass)\s+(?:all\s+|the\s+|any\s+|your\s+)?(?:previous|prior|above|earlier|preceding|system|original)\s+(?:instructions?|prompts?|rules?|guidelines?|directions?)/i
        $reassign_directive = /\b(?:new\s+(?:instructions?|rules?|directive|task)\s*[:=]?|your\s+(?:primary|real|new|actual)\s+(?:task|goal|objective)\s+(?:is\s+)?now|actually\s+respond\s+with|instead\s+(?:output|reply|respond|say)|from\s+now\s+on\s+you)\b/i
    semantics:
        $override_intent = "Content attempts to supersede, cancel, or replace the assistant's existing instructions, rules, or safety guidelines." (0.70)
    judge:
        $override_judge = "Assess whether public-safe facts indicate untrusted content is attempting to override or redefine the assistant's governing instructions." (0.65)
    condition:
        (($override_phrase or $reassign_directive) and $from_untrusted_origin) or $override_intent or $override_judge
}

rule IndirectContentInjection {
    meta:
        id          = cwfr-llm-0002
        version     = 0.1.0
        severity    = high
        scope       = event_window
        action      = block_and_audit
        technique   = AML.T0051.001 (Initial Access, direct)
        author      = "Project Open Hand Monk"
        status      = experimental
        description = "Detects injected instructions arriving through untrusted external content (retrieved pages, documents, tool output, hidden markup, or non-text modalities)."
        safety      = "Structural indirect-injection indicators only; no live external sources."
    patterns:
        $embedded_directive = /(?:<!--|\[\s*(?:system|assistant|instruction)\s*\]|hidden\s+(?:instruction|prompt)|when\s+(?:you|the\s+assistant)\s+(?:read|process|see)s?\s+this)/i
        $external_pivot     = /\b(?:visit|fetch|follow|open|load)\s+(?:my|the|this)\s+(?:website|link|url|resource|api)\b|external\s+resource|third[\s-]?party\s+data|in\s+the\s+(?:image|audio|attached\s+file)\s+(?:there|are|is)\b/i
    semantics:
        $indirect_intent = "External or retrieved content embeds instructions intended to steer the assistant rather than be treated as data." (0.70)
    judge:
        $indirect_judge = "Assess whether public-safe facts indicate untrusted external content is smuggling instructions for the assistant to follow." (0.65)
    condition:
        (($embedded_directive or $external_pivot) and $from_untrusted_origin) or $indirect_intent or $indirect_judge
}

rule PayloadSplittingInjection {
    meta:
        id          = cwfr-llm-0003
        version     = 0.1.0
        severity    = medium
        scope       = text_field
        action      = quarantine
        technique   = AML.T0051 (Initial Access, direct), T1027 (Defense Evasion, analogical)
        author      = "Project Open Hand Monk"
        status      = experimental
        description = "Detects injection payloads fragmented across variables or steps and reassembled to evade keyword inspection."
        safety      = "Structural fragmentation indicators only; no executable payload text."
    patterns:
        $fragment_assembly = /\b(?:concatenate|join|combine|assemble|append|merge)\b[^.\n]{0,40}\b(?:parts?|fragments?|pieces?|segments?|variables?|strings?|letters?|characters?)\b/i
        $piecewise_define  = /\b(?:part|piece|segment|var|step|chunk)\s*[0-9]\s*[:=]|\bfirst\s+part\b[^.\n]{0,30}\bsecond\s+part\b/i
    semantics:
        $splitting_intent = "Content builds an instruction or command out of separated fragments to avoid detection." (0.70)
    judge:
        $splitting_judge = "Assess whether public-safe facts indicate a split or staged payload is being reassembled to bypass inspection." (0.65)
    condition:
        (($fragment_assembly or $piecewise_define) and $instruction_shape) or $splitting_intent or $splitting_judge
}
