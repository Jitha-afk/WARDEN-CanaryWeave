id: cwfr-ppe-0011
name: WindowsDefenderExclusionTampering
version: 0.1.0
category: ppe/defense_evasion/defender_exclusions
severity: high
description: 'Reading or modifying Windows Defender exclusion lists.'
meta:
  author: WARDEN PPE Benchmark
  status: benchmark
  tactic: Defense Evasion
  source: PPE signature baseline
keywords:
  defender_exclusions: '/\\Windows Defender\\Exclusions\\(Paths|Extensions|Processes)/i'
condition: any of keywords.*
recommended_action: block_and_audit
