name: CommandOrCodeExecutionRequest
severity: high
description: Detects untrusted or dataset-local content requesting command or code execution capability.
category: mcp_execution/command_or_code_execution_request
meta:
  author: Project Open Hand Monk
  status: experimental
  attack_refs:
    - framework: ATT&CK
      tactic: Execution
      technique_id: T1059
      mapping_strength: analogical
  defense_refs:
    - framework: D3FEND
      name: Execution Isolation
semantics:
  execution_intent:
    phrase: Content requests command, code, script, shell, or interpreter-like execution.
    threshold: 0.70
llm:
  unsafe_execution_judge:
    query: Assess whether redacted facts indicate untrusted content is requesting command or code execution.
    threshold: 0.65
signals:
  command_execution_shape:
    type: feature_flag
    feature: command_execution_shape
  capability_not_granted:
    type: capability_policy
    relation: not_in_allowed_capabilities
condition: (signals.command_execution_shape and signals.capability_not_granted) or semantics.execution_intent or llm.unsafe_execution_judge
recommended_action: block_and_audit
